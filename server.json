{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "space.mcploadbudgeter/mcploadbudgeter-mcp",
  "title": "MCPLoad Budgeter MCP",
  "description": "Paid remote MCP for context budgets, progressive loading, schema slimming, and readiness.",
  "version": "0.1.0",
  "websiteUrl": "https://mcploadbudgeter.space/",
  "icons": [
    {
      "src": "https://mcploadbudgeter.space/favicon.svg",
      "mimeType": "image/svg+xml",
      "sizes": [
        "any"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcploadbudgeter.space/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer token issued after checkout and MCP token claim.",
          "isRequired": true,
          "isSecret": true,
          "placeholder": "Bearer <token>"
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "serverCardUrl": "https://mcploadbudgeter.space/.well-known/mcp/server-card.json",
      "accessModel": "paid_mcp_bearer_token"
    }
  }
}
